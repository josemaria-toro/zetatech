{
    "inputs": [
        {
            "description": "Github Token:",
            "id": "github_token",
            "password": true,
            "type": "promptString"
        }
    ],
    "tasks": [
        {
            "command": "dotnet restore Zetatech.Accelerate.sln --nologo --verbosity normal",
            "dependsOn": [],
            "dependsOrder": "sequence",
            "group": {
                "isDefault": false,
                "kind": "none"
            },
            "hide": true,
            "label": "zetatech: restore",
            "problemMatcher": "$msCompile",
            "type": "shell"
        },
        {
            "command": "dotnet clean Zetatech.Accelerate.sln --configuration Release --nologo --verbosity normal",
            "dependsOn": [
                "zetatech: restore"
            ],
            "dependsOrder": "sequence",
            "group": {
                "isDefault": false,
                "kind": "none"
            },
            "hide": true,
            "label": "zetatech: clean",
            "problemMatcher": "$msCompile",
            "type": "shell"
        },
        {
            "command": "dotnet build Zetatech.Accelerate.sln --configuration Release --nologo --no-restore --verbosity normal",
            "dependsOn": [
                "zetatech: clean"
            ],
            "dependsOrder": "sequence",
            "group": {
                "isDefault": false,
                "kind": "none"
            },
            "hide": true,
            "label": "zetatech: build",
            "problemMatcher": "$msCompile",
            "type": "shell"
        },
        {
            "command": "dotnet pack Zetatech.Accelerate.sln --configuration Release --include-source --include-symbols --nologo --no-restore --output .packages --verbosity normal",
            "dependsOn": [
                "zetatech: build"
            ],
            "dependsOrder": "sequence",
            "group": {
                "isDefault": false,
                "kind": "none"
            },
            "hide": false,
            "label": "zetatech: pack",
            "problemMatcher": [
                "$msCompile"
            ],
            "promptOnClose": false,
            "type": "shell"
        },
        {
            "command": "dotnet nuget push .packages/*.nupkg --source https://nuget.pkg.github.com/josemaria-toro/index.json --api-key ${input:github_token} --skip-duplicate",
            "dependsOn": [],
            "dependsOrder": "sequence",
            "group": {
                "isDefault": false,
                "kind": "none"
            },
            "hide": false,
            "label": "zetatech: release",
            "problemMatcher": [
                "$msCompile"
            ],
            "promptOnClose": false,
            "type": "shell"
        }
    ],
    "version": "2.0.0"
}